{
  "id": "terminal_sweep_suite",
  "name": "Terminal sweep suite",
  "description": "Seeded terminal-descent family plus one pinned checkpoint scenario for broader batch validation.",
  "entries": [
    {
      "id": "terminal_baseline_sweep",
      "family": "terminal_nominal",
      "base_scenario": "../scenarios/flat_terminal_descent.json",
      "controller": "baseline",
      "seed_range": {
        "start": 0,
        "count": 6
      },
      "tags": [
        "sweep",
        "terminal"
      ],
      "metadata": {
        "difficulty": "nominal_sweep"
      },
      "perturbations": [
        {
          "id": "spawn_dx",
          "path": "initial_state.position_m.x",
          "mode": "offset",
          "min": -14.0,
          "max": 14.0,
          "quantize": 0.5
        },
        {
          "id": "spawn_y",
          "path": "initial_state.position_m.y",
          "mode": "offset",
          "min": -10.0,
          "max": 12.0,
          "quantize": 0.5
        },
        {
          "id": "spawn_vx",
          "path": "initial_state.velocity_mps.x",
          "mode": "offset",
          "min": -2.0,
          "max": 2.0,
          "quantize": 0.25
        },
        {
          "id": "spawn_vy",
          "path": "initial_state.velocity_mps.y",
          "mode": "offset",
          "min": -2.5,
          "max": 2.5,
          "quantize": 0.25
        },
        {
          "id": "fuel_scale",
          "path": "vehicle.initial_fuel_kg",
          "mode": "scale",
          "min": 0.88,
          "max": 1.0,
          "quantize": 0.01
        }
      ]
    },
    {
      "id": "checkpoint_idle_reference",
      "scenario": "../scenarios/timed_checkpoint_idle.json",
      "controller": "idle"
    }
  ]
}
