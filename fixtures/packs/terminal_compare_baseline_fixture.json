  "description": "Small external-baseline fixture for pack-vs-pack compare smoke tests. This is not the primary controller workbench; use terminal_bot_lab_suite for day-to-day bot iteration.",
  "entries": [
    {
      "id": "terminal_compare_baseline",
      "family": "terminal_guidance_fixture_nominal",
      "base_scenario": "../scenarios/flat_terminal_descent.json",
      "controller": "baseline",
      "seed_range": {
        "start": 0,
        "count": 6
      },
      "tags": [
        "fixture",
        "compare",
        "terminal"
      ],
      "metadata": {
        "difficulty": "nominal_fixture",
        "mission": "terminal_guidance",
        "arrival_family": "seeded_terminal_arrival_v0",
        "condition_set": "clean",
        "vehicle_variant": "nominal",
        "expectation_tier": "stress"
      },
      "perturbations": [
        {
          "id": "spawn_dx",
          "path": "initial_state.position_m.x",
          "mode": "offset",
          "min": -14.0,
          "max": 14.0,
          "quantize": 0.5
        },
        {
          "id": "spawn_y",
          "path": "initial_state.position_m.y",
          "mode": "offset",
          "min": -10.0,
          "max": 12.0,
          "quantize": 0.5
        },
        {
          "id": "spawn_vx",
          "path": "initial_state.velocity_mps.x",
          "mode": "offset",
          "min": -2.0,
          "max": 2.0,
          "quantize": 0.25
        },
        {
          "id": "spawn_vy",
          "path": "initial_state.velocity_mps.y",
          "mode": "offset",
          "min": -2.5,
          "max": 2.5,
          "quantize": 0.25
        },
        {
          "id": "fuel_scale",
          "path": "vehicle.initial_fuel_kg",
          "mode": "scale",
          "min": 0.88,
          "max": 1.0,
          "quantize": 0.01
        }
      ]
    },
    {
      "id": "checkpoint_idle_reference",
      "scenario": "../scenarios/timed_checkpoint_idle.json",
      "controller": "idle",
      "metadata": {
        "mission": "checkpoint_validation",
        "arrival_family": "checkpoint_reference_v0",
        "condition_set": "clean",
        "vehicle_variant": "nominal",
        "expectation_tier": "reference"
      }
    }
  ]
