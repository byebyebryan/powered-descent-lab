{
  "id": "terminal_bot_lab_suite",
  "name": "Terminal bot-lab suite",
  "description": "Curated terminal-guidance controller suite over clean nominal and low-margin arrival cases, comparing the baseline and staged lanes while the explicit arrival-profile matrix is still being built.",
  "entries": [
    {
      "id": "terminal_guidance_clean_nominal_baseline",
      "family": "terminal_guidance_clean_nominal",
      "base_scenario": "../scenarios/flat_terminal_descent.json",
      "controller": "baseline",
      "seed_range": {
        "start": 0,
        "count": 5
      },
      "tags": [
        "terminal_guidance",
        "clean",
        "nominal",
        "bot_lab",
        "core"
      ],
      "metadata": {
        "difficulty": "nominal",
        "mission": "terminal_guidance",
        "arrival_family": "seeded_terminal_arrival_v0",
        "condition_set": "clean",
        "vehicle_variant": "nominal",
        "expectation_tier": "core"
      },
      "perturbations": [
        {
          "id": "spawn_dx",
          "path": "initial_state.position_m.x",
          "mode": "offset",
          "min": -14.0,
          "max": 14.0,
          "quantize": 0.5
        },
        {
          "id": "spawn_y",
          "path": "initial_state.position_m.y",
          "mode": "offset",
          "min": -10.0,
          "max": 12.0,
          "quantize": 0.5
        },
        {
          "id": "spawn_vx",
          "path": "initial_state.velocity_mps.x",
          "mode": "offset",
          "min": -2.0,
          "max": 2.0,
          "quantize": 0.25
        },
        {
          "id": "spawn_vy",
          "path": "initial_state.velocity_mps.y",
          "mode": "offset",
          "min": -2.5,
          "max": 2.5,
          "quantize": 0.25
        },
        {
          "id": "fuel_scale",
          "path": "vehicle.initial_fuel_kg",
          "mode": "scale",
          "min": 0.9,
          "max": 1.0,
          "quantize": 0.01
        }
      ]
    },
