{
  "id": "terminal_bot_lab_suite",
  "name": "Terminal bot-lab suite",
  "description": "Curated terminal-descent families for controller iteration, comparing the baseline and staged controllers across nominal, crossrange, and low-margin cases.",
  "entries": [
    {
      "id": "terminal_nominal_baseline",
      "family": "terminal_nominal",
      "base_scenario": "../scenarios/flat_terminal_descent.json",
      "controller": "baseline",
      "seed_range": {
        "start": 0,
        "count": 5
      },
      "tags": [
        "terminal",
        "nominal",
        "bot_lab"
      ],
      "metadata": {
        "difficulty": "nominal"
      },
      "perturbations": [
        {
          "id": "spawn_dx",
          "path": "initial_state.position_m.x",
          "mode": "offset",
          "min": -14.0,
          "max": 14.0,
          "quantize": 0.5
        },
        {
          "id": "spawn_y",
          "path": "initial_state.position_m.y",
          "mode": "offset",
          "min": -10.0,
          "max": 12.0,
          "quantize": 0.5
        },
        {
          "id": "spawn_vx",
          "path": "initial_state.velocity_mps.x",
          "mode": "offset",
          "min": -2.0,
          "max": 2.0,
          "quantize": 0.25
        },
        {
          "id": "spawn_vy",
          "path": "initial_state.velocity_mps.y",
          "mode": "offset",
          "min": -2.5,
          "max": 2.5,
          "quantize": 0.25
        },
        {
          "id": "fuel_scale",
          "path": "vehicle.initial_fuel_kg",
